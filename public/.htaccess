<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # 1. Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2. Force non-www (e.g., www.animecream.com -> animecream.com)
    RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

    # 3. Redirect legacy paths (301 permanent for SEO equity transfer)
    RewriteRule ^producciones/(.+)$ /$1 [R=301,L]
    RewriteRule ^anime/(.+)$ /$1 [R=301,L]

    # 4. Serve existing files and directories as-is
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # 5. All other routes (/[slug], /list/*) → index.html (SPA fallback)
    RewriteRule ^ index.html [L]
</IfModule>
